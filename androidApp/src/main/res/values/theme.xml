<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="background">@color/background_color</item>
    </style>

    <!-- SplashScreen theme. -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background, animated icon, and animation duration. -->
        <item name="windowSplashScreenBackground">@color/background_color</item>

        <!--  Use windowSplashScreenAnimatedIcon to add either a drawable or an -->
        <!--  animated drawable. One of these is required. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>

        <!-- Set the theme of the Activity that directly follows your splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.AppTheme</item>
    </style>
</resources>